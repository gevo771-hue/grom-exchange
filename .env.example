# ================== GROM EXCHANGE ENV ==================
# All variables use GROM_ prefix to avoid collision with Granium.

NODE_ENV=development

# --- Ports ---
GROM_BACKEND_PORT=4000
GROM_FRONTEND_PORT=5273

# --- Postgres ---
GROM_DB_HOST=postgres
GROM_DB_PORT=5432
GROM_DB_NAME=grom
GROM_DB_USER=grom
GROM_DB_PASSWORD=change_me_strong_password

# --- Redis ---
GROM_REDIS_HOST=redis
GROM_REDIS_PORT=6379
GROM_REDIS_NAMESPACE=grom:

# --- Auth / Security ---
GROM_JWT_SECRET=change_me_64_chars_min_random_string
GROM_JWT_TTL=86400
GROM_CORS_ORIGIN=http://localhost:5273
# Same host the browser uses (nginx on 5273 → /auth SIWE domain must match).
GROM_SIWE_DOMAIN=localhost:5273
# Local-only: POST /auth/dev-login returns JWT without MetaMask (never enable in production).
GROM_ALLOW_DEV_LOGIN=1

# --- Binary Options Engine ---
GROM_BO_MIN_STAKE=1
GROM_BO_MAX_STAKE=10000
GROM_BO_PAYOUT_RATIO=0.92
GROM_BO_ROUND_DURATIONS=30,60,300,900
GROM_BO_COOLDOWN_MS=500
GROM_BO_DEMO_BALANCE=10000

# --- Liquidity: Binance ---
GROM_BINANCE_API_KEY=
GROM_BINANCE_API_SECRET=
GROM_BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# --- Liquidity: Kraken (fallback) ---
GROM_KRAKEN_API_KEY=
GROM_KRAKEN_API_SECRET=
GROM_KRAKEN_WS_URL=wss://ws.kraken.com/v2

# --- Liquidity: Coinbase (fallback) ---
GROM_COINBASE_API_KEY=
GROM_COINBASE_API_SECRET=
GROM_COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com

# --- DEX Aggregators ---
GROM_1INCH_API_KEY=
GROM_ODOS_API_URL=https://api.odos.xyz

# --- Web3 Wallet ---
GROM_WALLETCONNECT_PROJECT_ID=
GROM_SUPPORTED_CHAINS=1,137,56,42161,8453
GROM_SIWE_STATEMENT=Sign in to GROM Exchange

# --- Hummingbot (internal MM) ---
GROM_HUMMINGBOT_API_URL=http://hummingbot:15888
GROM_HUMMINGBOT_API_KEY=

# --- Observability ---
GROM_LOG_LEVEL=info
GROM_METRICS_PORT=9464
GROM_PROMETHEUS_URL=http://prometheus:9090
SENTRY_DSN=
SENTRY_PUBLIC_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05

# --- Email / SendGrid ---
EMAIL_FROM=GROM <noreply@grom.exchange>
EMAIL_DRY_RUN=true
SENDGRID_API_KEY=
SENDGRID_API_URL=https://api.sendgrid.com/v3/mail/send

# --- Sumsub KYC ---
KYC_PROVIDER=sumsub
SUMSUB_API_KEY=
SUMSUB_SECRET=
SUMSUB_WEBHOOK_SECRET=
SUMSUB_LEVEL=basic-kyc-level
SUMSUB_BASE_URL=https://test-api.sumsub.com

# --- MoonPay on-ramp ---
MOONPAY_PUBLIC_KEY=
MOONPAY_SECRET_KEY=
MOONPAY_WEBHOOK_SECRET=
MOONPAY_ENV=sandbox
MOONPAY_BASE_URL=https://buy-sandbox.moonpay.com

# --- Hot wallet signers ---
SIGNERS_DRY_RUN=true
HOT_WALLET_EVM_KEY=
HOT_WALLET_EVM_KMS_KEY_ID=
RPC_ETH=
RPC_ARB=
RPC_MATIC=
RPC_BASE=
RPC_BSC=
USDT_ETH_CONTRACT=
USDC_ETH_CONTRACT=
USDT_ARB_CONTRACT=
USDC_ARB_CONTRACT=
USDT_MATIC_CONTRACT=
USDC_MATIC_CONTRACT=
USDT_BASE_CONTRACT=
USDC_BASE_CONTRACT=
USDT_BSC_CONTRACT=
USDC_BSC_CONTRACT=
TRON_FULL_HOST=https://api.trongrid.io
TRON_API_KEY=
TRON_HOT_WALLET_KEY=
HOT_WALLET_TRON_KEY=
HOT_WALLET_TRON_KMS_KEY_ID=
USDT_TRON_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
USDC_TRON_CONTRACT=
ESPLORA_API=https://blockstream.info/api
BTC_UTXO_API=https://blockstream.info/api
BTC_HOT_WALLET_WIF=
BTC_HOT_WALLET_ADDRESS=
HOT_WALLET_BTC_KEY=
HOT_WALLET_BTC_KMS_KEY_ID=
BTC_NETWORK=bitcoin
BTC_FEE_BLOCK_TARGET=6
BTC_FEE_RATE_SAT_VB=15
BTC_DUST_SATS=546
CONFIRMATIONS_ETH=12
CONFIRMATIONS_ARB=12
CONFIRMATIONS_MATIC=32
CONFIRMATIONS_BASE=12
CONFIRMATIONS_BSC=15
CONFIRMATIONS_TRON=19
CONFIRMATIONS_BTC=6

# --- Autonomous Market Maker ---
BINANCE_HOT_WALLET=false
MM_ENABLED=false
MM_USER_ID=00000000-0000-4000-8000-0000000000aa
MM_DRY_RUN=true
MM_REFRESH_MS=3000
MM_REQUOTE_THRESHOLD_BPS=5
MM_MAX_TOTAL_DRAWDOWN_USDT=500
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_USE_TESTNET=true
BINANCE_DRY_RUN=true
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_REST_URL=https://testnet.binance.vision
BINANCE_DEPOSIT_RECONCILE_MS=30000
BINANCE_CONFIRM_WATCHER_MS=30000
BINANCE_MAX_WITHDRAWAL_USD=5000
BINANCE_ALERT_ON_FAILURES=3

# --- Geoblock (ISO country codes, comma separated, blocked). Empty = disabled (good for local dev). ---
GROM_GEOBLOCK=
